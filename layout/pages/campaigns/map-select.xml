<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>
	<scripts>
		<include src="file://{scripts}/common/dev.ts" />
		<include src="file://{resources}/scripts/pages/campaigns/shared.ts" />
		<include src="file://{resources}/scripts/pages/campaigns/map-select.ts" />
	</scripts>

	<snippets>
		<snippet name="MapEntrySnippet">
			<RadioButton group="MapsGroupRadio" class="campaign-maps__entry" tabindex="auto" selectionpos="auto">
				<Image
					id="Cover"
					class="campaign-maps__entry__cover"
					defaultsrc="file://{images}/menu/p2ce-generic.png"
					scaling="stretch-to-cover-preserve-aspect"
				/>
				<Panel class="campaign-maps__entry__details">
					<Label id="Title" class="campaign-maps__entry__details__title" />
				</Panel>
			</RadioButton>
		</snippet>
	</snippets>

	<Panel class="campaign-settings__grouper__bg" onload="CampaignMapSelect.onLoad()">
		<Panel id="SettingPageInsert" class="campaign-maps">

		</Panel>
	</Panel>
</root>
