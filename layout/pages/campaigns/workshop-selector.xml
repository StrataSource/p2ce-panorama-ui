<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>
	<scripts>
		<include src="file://{scripts}/common/dev.ts" />
		<include src="file://{scripts}/common/searcher.ts" />
		<include src="file://{scripts}/pages/campaigns/workshop-selector.ts" />
	</scripts>

	<snippets>
		<snippet name="WorkshopEntrySnippet">
			<Button group="WorkshopGroupRadio" class="workshop__entry" tabindex="auto" selectionpos="auto">
				<Panel class="workshop__entry__top">
					<Image
						id="Cover"
						class="workshop__entry__cover"
						scaling="stretch-to-cover-preserve-aspect"
					/>
					<Panel id="NewIndicator" class="workshop__entry__new-indicator hide">
						<Label class="workshop__entry__new-indicator__text" text="#MainMenu_Content_Unplayed" />
					</Panel>
					<TooltipPanel
						id="Indicator"
						class="workshop__entry__indicator fancy-red hide"
						tooltip="#DependencyWarning_Generic"
					>
						<Image
							scaling="stretch-to-fit-preserve-aspect"
							src="file://{images}/alert-octagon.svg"
							texturewidth="64"
							textureheight="64"
						/>
					</TooltipPanel>
				</Panel>
				<Panel class="workshop__entry__details">
					<Label class="workshop__entry__details__desc" text="{s:name}" />
				</Panel>
			</Button>
		</snippet>
	</snippets>

	<Panel class="mainmenu__page" onload="WorkshopSelector.init()">
		<Panel class="workshop__top-bar">
			<TextEntry id="SearchBar" class="textentry workshop__search" placeholder="#Common_SearchEllipsis" />
			<Button
				class="button ml-2"
				onactivate="SteamOverlayAPI.OpenURL('https://steamcommunity.com/workshop/browse/?appid=440000&amp;browsesort=trend&amp;section=readytouseitems&amp;p=1&amp;num_per_page=30&amp;days=7&amp;requiredtags%5B%5D=Map')"
				tabindex="auto"
				selectionpos="auto"
			>
				<Image
					class="button__icon button__icon--left"
					texturewidth="64"
					textureheight="64"
					src="file://{images}/icons/steam.svg"
				/>
				<Label class="button__text button__text--right" text="#MainMenu_Campaigns_OpenWS" />
			</Button>
		</Panel>
		<Panel id="EntryInsert" class="workshop__entries" />
		<Panel class="workshop__action-bar">
			<Button class="button">
				<Label class="button__text" text="[HC] Play" />
			</Button>
		</Panel>
	</Panel>
</root>
