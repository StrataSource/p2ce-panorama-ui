<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>
	<scripts>
		<include src="file://{scripts}/common/dev.ts" />
		<include src="file://{scripts}/pages/featured/shared.js" />
		<include src="file://{scripts}/pages/featured/main.ts" />
	</scripts>

	<Panel class="mainmenu__page flow-right" onload="FeaturedMenu.onLoad()">
		<Panel class="featured__scroller">
			<Button class="featured__entry" onactivate="FeaturedMenu.open(0)">
				<Image
					class="featured__entry__boxart"
					scaling="stretch-to-cover-preserve-aspect"
					src="file://{images}/menu/featured/gallery/00_winter-2024.png"
				/>
				<Panel class="featured__entry__details">
					<Label class="featured__entry__details__text" text="[HC] Holiday Mapping Competition 2024" />
				</Panel>
			</Button>
			<Button class="featured__entry" onactivate="FeaturedMenu.open(1)">
				<Image
					class="featured__entry__boxart"
					scaling="stretch-to-cover-preserve-aspect"
					src="file://{images}/menu/featured/gallery/01_open-beta.png"
				/>
				<Panel class="featured__entry__details">
					<Label class="featured__entry__details__text" text="[HC] Open Beta 2026" />
				</Panel>
			</Button>
			<Button disabled="true" class="featured__entry">
				<Image
					class="featured__entry__boxart"
					scaling="stretch-to-cover-preserve-aspect"
					src="file://{images}/menu/banner-multiverse.png"
				/>
				<Panel class="featured__entry__details">
					<Label class="featured__entry__details__text" text="[HC] Coming Soon..." />
				</Panel>
			</Button>
		</Panel>
	</Panel>
</root>
