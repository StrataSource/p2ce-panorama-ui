<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>
	<scripts>
		<include src="file://{scripts}/common/dev.ts" />
		<include src="file://{scripts}/pages/main-menu/campaign-menu.ts" />
	</scripts>

	<Panel class="full" hittest="false" hittestchildren="false" onload="CampaignMenu.onLoad()">
