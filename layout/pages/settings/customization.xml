<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>
	<scripts>
		<include src="file://{scripts}/pages/settings/page.js" />
		<!-- Temporary -->
		<include src="file://{scripts}/util/dosa.ts" />
	</scripts>

	<Panel class="settings-page" searchtitle="#Settings_Customization">
		<Panel id="SettingsPageContainer" class="settings-page__container">
			<Panel id="PortalsSubSection" class="settings-group">
				<Panel class="settings-group__header">
					<Label class="settings-group__title" text="#Settings_Portals_Title" tags="portals, portal, color, customization" />
				</Panel>

				<SettingsEnum
					text="#Settings_Portals_PlayerFunnel"
					convar="sv_player_funnel_into_portals"
					infomessage="#Settings_Portals_PlayerFunnel_info"
					hasdocspage="false"
				>
					<RadioButton group="sv_player_funnel_into_portals" text="#Common_Off" value="0" />
					<RadioButton group="sv_player_funnel_into_portals" text="#Common_On" value="1" />
				</SettingsEnum>

				<SettingsEnum
					text="#Settings_Portals_altcolors"
					convar="cl_portal_alternate_colors"
					infomessage="#Settings_Portals_altcolors_info"
					hasdocspage="false"
				>
					<RadioButton group="portal_altcolors" text="#Common_Off" value="0" />
					<RadioButton group="portal_altcolors" text="#Common_On" value="1" />
				</SettingsEnum>

				<ConVarColorDisplay
					text="#Settings_Portals_altcolors_primary"
					convar="cl_portal_sp_primary_color"
					infomessage="#Settings_Portals_altcolors_primary_Info"
					hasdocspage="false"
				/>
				<ConVarColorDisplay
					text="#Settings_Portals_altcolors_secondary"
					convar="cl_portal_sp_secondary_color"
					infomessage="#Settings_Portals_altcolors_secondary_Info"
					hasdocspage="false"
				/>
			</Panel>

			<Panel class="settings-page__spacer" />

			<Panel id="GelsSubSection" class="settings-group">
				<Panel class="settings-group__header">
					<Label class="settings-group__title" text="#Settings_Gels_Title" tags="gels, customization" />

					<TooltipPanel class="settings-group__reset" tooltip="#Settings_General_Reset">
						<Button class="button settings-group__reset" onactivate="SettingsShared.resetSettings('GelsSubSection');">
							<Image class="button__icon" texturewidth="64" textureheight="64" src="file://{images}/reset.svg" />
						</Button>
					</TooltipPanel>
				</Panel>

				<ConVarColorDisplay
					text="#Settings_Gels_repulsion_color"
					infomessage="#Settings_Gels_repulsion_color_Info"
					convar="bounce_paint_color"
					hasdocspage="false"
				/>
				<ConVarColorDisplay
					text="#Settings_Gels_propulsion_color"
					infomessage="#Settings_Gels_propulsion_color_Info"
					convar="speed_paint_color"
					hasdocspage="false"
				/>
				<ConVarColorDisplay
					text="#Settings_Gels_conversion_color"
					infomessage="#Settings_Gels_conversion_color_Info"
					convar="portal_paint_color"
					hasdocspage="false"
				/>
				<ConVarColorDisplay
					text="#Settings_Gels_reflection_color"
					infomessage="#Settings_Gels_reflection_color_Info"
					convar="reflect_paint_color"
					hasdocspage="false"
				/>
				<ConVarColorDisplay
					text="#Settings_Gels_adhesion_color"
					infomessage="#Settings_Gels_adhesion_color_Info"
					convar="stick_paint_color"
					hasdocspage="false"
				/>
			</Panel>

			<Panel class="settings-page__spacer" />

			<Panel id="MiscSubSection" class="settings-group">
				<Panel class="settings-group__header">
					<Label class="settings-group__title" text="#Settings_Misc_Title" tags="misc, customization" />
				</Panel>

				<SettingsSlider
					text="#Settings_Misc_ViewmodelOffset_X"
					infomessage="#Settings_Misc_ViewmodelOffset_X_info"
					min="-20"
					max="10"
					displayprecision="3"
					convar="viewmodel_offset_x"
					hasdocspage="false"
					viewgameduringedit="true"
				/>
				<SettingsSlider
					text="#Settings_Misc_ViewmodelOffset_Y"
					infomessage="#Settings_Misc_ViewmodelOffset_Y_info"
					min="-10"
					max="10"
					displayprecision="3"
					convar="viewmodel_offset_y"
					hasdocspage="false"
					viewgameduringedit="true"
				/>
				<SettingsSlider
					text="#Settings_Misc_ViewmodelOffset_Z"
					infomessage="#Settings_Misc_ViewmodelOffset_Z_info"
					min="-5"
					max="5"
					displayprecision="3"
					convar="viewmodel_offset_z"
					hasdocspage="false"
					viewgameduringedit="true"
				/>
			</Panel>
		</Panel>
	</Panel>
</root>
