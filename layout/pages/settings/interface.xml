<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
	</styles>
	<scripts>
		<include src="file://{scripts}/pages/settings/page.js" />
		<!-- Temporary -->
		<include src="file://{scripts}/util/dosa.ts" />
	</scripts>

	<Panel class="settings-page">

		<Panel class="settings-page__header">

			<Label class="settings-page__title" text="#Settings_Interface" />

			<Panel class="settings-page__header-buttons">
			</Panel>

		</Panel>

		<Panel id="SettingsPageContainer" class="settings-page__container">

			<Panel id="UISubSection" class="settings-group">
				<Panel class="settings-group__header">
					<Label class="settings-group__title" text="#Settings_Menu_Title" tags="menu,ui" />
					<TooltipPanel class="settings-group__reset" tooltip="#Settings_General_Reset">
						<Button class="button settings-group__reset" onactivate="SettingsShared.resetSettings('UISubSection');">
							<Image class="button__icon" src="file://{images}/reset.svg" />
						</Button>
					</TooltipPanel>
				</Panel>

				<SettingsEnum
					text="#Settings_Menu_Console"
					infomessage="#Settings_Menu_Console_info"
					convar="con_enable"
					hasdocspage="false"
					tags="console"
				>
					<RadioButton group="enableconsole" text="#Common_Off" value="0" />
					<RadioButton group="enableconsole" text="#Common_On" value="1" />
				</SettingsEnum>

				<!-- TODO: LOCALISE AND MOVE THIS SOMEWHERE ELSE!!!! -->
				<SettingsEnum
					id="SentryReporting"
					text="#Settings_Menu_Sentry"
					infomessage="#Settings_Menu_Sentry_info"
					hasdocspage="false"
					tags="sentry"
				>
					<Button class="button horizontal-align-right" onactivate="SettingsShared.sentryUpdateConsent()">
						<Label class="button__text" text="Update Consent" />
					</Button>
				</SettingsEnum>

				<!-- TODO: Temp! -->
				<SettingsEnum
					text="#Settings_Menu_DiscordIntegration"
					infomessage="#Settings_Menu_DiscordIntegration_info"
					convar="cl_richpresence_enable"
					hasdocspage="false"
					tags="richpresence"
				>
					<RadioButton group="enablerpc" text="#Common_Off" value="0" />
					<RadioButton group="enablerpc" text="#Common_On" value="1" />
				</SettingsEnum>

				<SettingsEnum
					text="Playtest Consent (DO NOT LOCALIZE)"
					infomessage="Playtest Consent (DO NOT LOCALIZE)"
					convar="cl_playtest_enabled"
					hasdocspage="false"
					tags="consent"
				>
					<RadioButton group="enableconsent" text="#Common_Off" value="0" />
					<RadioButton group="enableconsent" text="#Common_On" value="1" />
				</SettingsEnum>
 
				<ConVarEnabler convar="developer" togglevisibility="true">
					<SettingsEnum
						id="PlaytestDOSARemove"
						text="Playtest DOSA remove (DO NOT LOCALIZE)"
						infomessage="Remove DOSA from playtest consent (For development purposes)"
						hasdocspage="false"
						tags="dosa"
					>
						<Button class="button horizontal-align-right" onactivate="SettingsShared.PlayTestDosaRemove()">
							<Label class="button__text" text="Remove DOSA" />
						</Button>
					</SettingsEnum>
				</ConVarEnabler>
			</Panel>

			<Panel class="settings-page__spacer" />

			<Panel id="CCSection" class="settings-group">
				<Panel class="settings-group__header">
					<Label class="settings-group__title" text="[HC] Closed Captions" tags="menu,ui" />
					<TooltipPanel class="settings-group__reset" tooltip="#Settings_General_Reset">
						<Button class="button settings-group__reset" onactivate="SettingsShared.resetSettings('UISubSection');">
							<Image class="button__icon" src="file://{images}/reset.svg" />
						</Button>
					</TooltipPanel>
				</Panel>

				<SettingsSlider
					text="[HC] [NOT IMPLEMENTED] Background Opacity"
					infomessage="[HC]"
					psvar="cc.bg_opacity"
					min="0"
					max="1"
					percentage="true"
					hasdocspage="false"
					changeoverride="$.DispatchEvent('ReloadCCSettings')"
				/>

				<SettingsSlider
					text="[HC] [NOT IMPLEMENTED] Font Size"
					infomessage="[HC]"
					psvar="cc.font_size"
					min="18"
					max="26"
					increment="1"
					hasdocspage="false"
					changeoverride="$.DispatchEvent('ReloadCCSettings')"
				/>

				<SettingsEnumDropDown
					text="[HC] Font"
					infomessage="[HC]"
					psvar="cc.font"
					submitoverride="$.DispatchEvent('ReloadCCSettings')"
				>
					<Label text="[HC] Default (GorDIN)" value="0" id="ccfont0" />
					<Label text="[HC] Portal 2 (Univers)" value="1" id="ccfont1" />
					<Label text="[HC] P2:CE (Lexend Deca)" value="2" id="ccfont2" />
					<Label text="[HC] Classic (Verdana)" value="3" id="ccfont3" />
				</SettingsEnumDropDown>

				<SettingsEnum
					text="[HC] Text Alignment"
					infomessage="[HC]"
					psvar="cc.text_align"
					tags="cc,closecaption,captions,audio"
				>
					<RadioButton
						group="ccalign"
						text="[HC] Left"
						value="0"
						activateoverride="$.DispatchEvent('ReloadCCSettings')"
					/>
					<RadioButton
						group="ccalign"
						text="[HC] Center"
						value="1"
						activateoverride="$.DispatchEvent('ReloadCCSettings')"
					/>
				</SettingsEnum>
			</Panel>
		</Panel>
	</Panel>
</root>
